<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Package name="~de.cyclingsir.cetrack.infrastructure.api.model.*" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
<!-- https://stackoverflow.com/questions/72394653/how-to-ignore-ei-expose-rep2-in-case-of-spring-autowired-components
     e.g. a @Service with a method like addPart, setPart suggesting (falsely) modification used in a @RestController's
      constructor will be flagged.
      The service however isn't modified by the method, the database is but this doesn't harm the controller.
       -->
        <Method name="&lt;init&gt;"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="~.*\.storage\..*" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.support.DerbyFixtureBuilder" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Class name="~.*\.storage\..*" />
        <Method name="~set.*" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Class name="~.*\.storage\..*" />
        <Bug pattern="NP_NONNULL_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR" />
    </Match>
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION" />
    </Match>
    <!-- Kotlin lateinit var @MockK/@Autowired: all NP and UWF are false positives in test/IT classes -->
    <Match>
        <Class name="~.*(Test|IT)" />
        <Bug code="NP" />
    </Match>
    <Match>
        <Class name="~.*(Test|IT)" />
        <Bug pattern="UWF_UNWRITTEN_FIELD" />
    </Match>
    <!-- DerbyReadAdapterTest: lateinit var generates a redundant null-check in bytecode (RCN) -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapterTest" />
        <Bug code="RCN" />
    </Match>
    <!-- Kotlin's use{} closes JDBC resources in test; SpotBugs bytecode analysis misses this -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapterTest" />
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapterTest" />
        <Bug pattern="ODR_OPEN_DATABASE_RESOURCE" />
    </Match>
    <!-- PostgreSQLContainerIT companion object exposes container reference intentionally -->
    <Match>
        <Class name="de.cyclingsir.cetrack.support.PostgreSQLContainerIT$Companion" />
        <Bug pattern="MS_EXPOSE_REP" />
    </Match>
    <!-- Kotlin companion object init generates a SA false positive in bytecode -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.rest.MyTourbookImportControllerTest" />
        <Bug code="SA" />
    </Match>
    <!-- Kotlin data class List fields are read-only via the List interface -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.domain.DomainImportSession" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.domain.DomainImportWarning" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapter$ReadResult" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- Kotlin's use{} closes JDBC resources; SpotBugs bytecode analysis misses this -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapter" />
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapter" />
        <Bug pattern="ODR_OPEN_DATABASE_RESOURCE" />
    </Match>
    <!-- Optional.orElseThrow() return is non-null; SpotBugs bytecode analysis false positive -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.domain.ArchiveExtractor" />
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
    </Match>
    <!-- Kotlin backtick JUnit 5 test names compile to JVM method names starting with uppercase -->
    <Match>
        <Class name="~.*(Test|IT)" />
        <Bug pattern="NM_METHOD_NAMING_CONVENTION" />
    </Match>
    <!-- MyTourbookImportIT companion vals are test fixtures; Kotlin List is effectively immutable -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.domain.MyTourbookImportIT$Companion" />
        <Bug pattern="MS_EXPOSE_REP" />
    </Match>
    <!-- DerbyFixtureBuilder builds a local in-memory Derby DB; SQL injection risk is not applicable -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.support.DerbyFixtureBuilder" />
        <Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE" />
    </Match>
    <!-- TourSpec data class: Kotlin val List<UUID> is read-only; data class generates component2/getBikeTags -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.support.TourSpec" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- Kotlin data class: tourTypeIds List<Int> is read-only via the List interface -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.configuration.MyTourbookImportConfiguration" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- FitImportService.DraftWithHint: existingMatches List is read-only via the List interface -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.domain.FitImportService$DraftWithHint" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- FitParsedSession: internal data class; SessionMesg and List<FitRecord> not exposed to untrusted code -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.fit.FitParsedSession" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- FitMovingTimeKt: Kotlin smart-cast guards the nullable Float access; SpotBugs misses it at bytecode level -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.fit.FitMovingTimeKt" />
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
    </Match>
    <!-- DerbyReadAdapterTest companion: TOUR_TYPE_IDS is Kotlin listOf() — effectively immutable -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.derby.DerbyReadAdapterTest$Companion" />
        <Bug pattern="MS_EXPOSE_REP" />
    </Match>
    <!-- Kotlin MockMvc/MockK initializer blocks generate SA_LOCAL_SELF_ASSIGNMENT in bytecode -->
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.rest.FitImportControllerTest" />
        <Bug code="SA" />
    </Match>
    <Match>
        <Class name="de.cyclingsir.cetrack.tour.rest.TourControllerTest" />
        <Bug code="SA" />
    </Match>
    <!-- Kotlin data class: created/closed/membershipChanges Lists are read-only via the List interface -->
    <Match>
        <Class name="de.cyclingsir.cetrack.mounting.domain.DomainMountingChanges" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <!-- ServiceException.details: read-only Map handed to the error body once -->
    <Match>
        <Class name="de.cyclingsir.cetrack.common.errorhandling.ServiceException" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
</FindBugsFilter>
